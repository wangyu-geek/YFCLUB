{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "永丰文体会员管理系统",
  "version": "0.1.0",
  "identifier": "com.yfclub.memberclub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "永丰文体会员管理系统",
        "width": 1540,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "../Hein53.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
